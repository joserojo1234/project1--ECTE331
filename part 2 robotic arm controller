public class MotorController {

    public synchronized void accessMotor(String threadName) {

        long enterTime = System.currentTimeMillis();

        System.out.println(enterTime + " : " + threadName + " entered MotorController");

        try {
            if (threadName.equals("Logger")) {
                System.out.println(threadName + " is holding the motor for longer time");
                Thread.sleep(3000);
            } else {
                Thread.sleep(500);
            }
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }

        long exitTime = System.currentTimeMillis();

        System.out.println(exitTime + " : " + threadName + " leaving MotorController");
    }
}


