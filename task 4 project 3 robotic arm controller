public class LoggerThread extends Thread {

    private MotorController motor;

    public LoggerThread(MotorController motor){
        this.motor = motor;
        setPriority(MIN_PRIORITY);
    }

    public void run(){

        while(true){

            motor.accessMotor("Logger");

            try{
                Thread.sleep(1000);
            }catch(Exception e){}

        }

    }

}
public class Main {

    public static void main(String[] args) {

        MotorController motor = new MotorController();

        SafetyMonitor safety = new SafetyMonitor(motor);
        MotionPlanner motion = new MotionPlanner(motor);
        LoggerThread logger = new LoggerThread(motor);

        safety.start();
        motion.start();
        logger.start();

    }

}
